---
import { storyblokEditable } from '@storyblok/astro';
import ChevronRight from '@/assets/svg/chevron-right.svg';

const { blok } = Astro.props;
const { title, description, image, link } = blok;
---

<div class="carousel-tile group" {...storyblokEditable(blok)}>
  <div class="flex flex-col justify-end h-full min-h-[390px] p-3 lg:p-5">
    <img
      src={image.filename}
      alt={image.alt}
      class="absolute inset-0 size-full object-cover group-hover:scale-103 transition-all duration-200 ease-out"
    />
    <div class="absolute inset-0 bg-black/40 z-1"></div>

    <div class="flex gap-4 z-1 items-end">
      <div>
        <h5 class="text-white font-display z-1">{title}</h5>
        <p class="text-white z-1 mb-0">{description}</p>
      </div>

      <a
        href={link.cached_url || link.url}
        class="icon size-7 aspect-square bg-primary group-hover:bg-black flex items-center justify-center mb-1 mr-1 transition-all duration-200 ease-out"
      >
        <ChevronRight />
      </a>
    </div>
  </div>
</div>
