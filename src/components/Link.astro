---
import { getLinkAttributes } from "@/utils/helper";
import { twJoin } from "tailwind-merge";

const { link, className = "" } = Astro.props;

const { href, title, target, rel } = getLinkAttributes(link);
---

<a
  href={href}
  title={title}
  target={target}
  rel={rel}
  class={twJoin("button", className)}>{title}</a
>
