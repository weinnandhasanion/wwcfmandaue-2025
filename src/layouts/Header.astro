---
import logo from "@/assets/images/logo-white.png";
import { twJoin } from "tailwind-merge";
import Link from "@/components/Link.astro";

const { links, cta } = Astro.props;
const pathname = Astro.url.pathname;

const isHome = pathname === "/" || pathname === "/home";
---

<header
  class="w-full absolute top-0 space py-0 text-white z-[100] bg-transparent"
>
  <div
    class={twJoin(
      "mx-container py-4 bg-transparent border-white",
      isHome && "md:border-b",
    )}
  >
    <div class="flex justify-between items-center">
      <a href="/" class="logo">
        <img src={logo.src} alt="Logo" class="h-8 lg:h-10 object-cover" />
      </a>

      <button
        id="mobile-menu-open"
        class="lg:hidden flex items-center justify-center p-2 rounded-sm hover:bg-white/10 focus:outline-none"
        aria-label="Open navigation menu"
        type="button"
      >
        <svg
          class="w-7 h-7 text-white"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <div class="hidden lg:flex items-center gap-8">
        {
          links.map(({ link, navigation_items }: any) => (
            <div class="group relative">
              <div class="flex items-center gap-1.5">
                <Link link={link} className="link light" />
                {!!navigation_items?.length && (
                  <svg
                    class="w-2.5 h-2.5 transition-transform duration-200 group-hover:rotate-180"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19 9l-7 7-7-7"
                    />
                  </svg>
                )}
              </div>
              {!!navigation_items?.length && (
                <div class="invisible opacity-0 -translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 ease-out absolute top-full -left-6 pt-2">
                  <div class="py-2 min-w-[200px] rounded-md bg-white/95 flex flex-col">
                    {navigation_items.map((item: any) => (
                      <Link
                        link={item.link}
                        className="menu-link link text-black text-[13px] px-6 hover:bg-primary/10 hover:text-primary py-2 transition-all duration-300 ease-out w-full"
                      />
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))
        }

        {cta && <Link link={cta} className="button light" />}
      </div>
    </div>
  </div>
</header>

<div
  id="mobile-menu"
  class="lg:hidden fixed inset-0 bg-black text-white z-[101] space py-0 -translate-x-full opacity-0"
>
  <div class="mx-container py-4">
    <div class="flex justify-between items-center">
      <a href="/">
        <img
          id="mobile-logo"
          src={logo.src}
          alt="Logo"
          class="h-8 lg:h-10 object-cover opacity-0"
        />
      </a>

      <button
        id="mobile-menu-close"
        class="flex items-center justify-center p-2 rounded-sm hover:bg-white/10 focus:outline-none"
        aria-label="Close navigation menu"
        type="button"
      >
        <svg
          class="w-7 h-7 text-white"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div id="mobile-menu-items" class="flex flex-col gap-4 mt-6 opacity-0">
      {
        links.map(({ link, navigation_items }: any) => (
          <a
            href={link.cached_url || link.url}
            class="group flex items-center justify-between gap-1.5 w-full border-b border-white/30 pb-2 link light text-lg"
          >
            {link.title}
            {navigation_items && navigation_items.length > 0 && (
              <svg
                class="w-3.5 h-3.5 ml-1 text-white"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            )}
          </a>
        ))
      }

      <a
        href={cta.cached_url || cta.url}
        class="group flex items-center justify-between gap-1.5 w-full border-b border-white/30 last:border-none pb-2 link light text-lg"
      >
        {cta.title}
      </a>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const header = document.querySelector("header");
  const pageBanner = document.querySelector(".page-banner");

  if (pageBanner && pageBanner.classList.contains("bg-white")) {
    header?.classList.add("!bg-primary");
  }

  const menu = document.getElementById("mobile-menu")!;
  const openBtn = document.getElementById("mobile-menu-open")!;
  const closeBtn = document.getElementById("mobile-menu-close")!;
  const mobileLogo = document.getElementById("mobile-logo")!;
  const mobileMenuItems = document.getElementById("mobile-menu-items")!;

  openBtn.addEventListener("click", () => {
    document.body.style.overflow = "hidden";
    const enterTimeline = gsap.timeline();
    enterTimeline.to(menu, {
      transform: "translateX(0)",
      backgroundColor: "#3366cc",
      duration: 0.4,
      opacity: 1,
      ease: "power2.inOut",
    });
    enterTimeline.to(
      [mobileLogo, mobileMenuItems],
      {
        opacity: 1,
        duration: 0.3,
        ease: "power2.inOut",
      },
      "-=0.1",
    );
  });

  closeBtn.addEventListener("click", () => {
    const exitTimeline = gsap.timeline();
    exitTimeline.to(menu, {
      transform: "translateX(-100%)",
      backgroundColor: "black",
      duration: 0.5,
      ease: "power2.inOut",
    });
    exitTimeline.to(
      [menu, mobileLogo, mobileMenuItems],
      {
        opacity: 0,
        duration: 0.3,
        ease: "power2.inOut",
      },
      "-=0.25",
    );
    document.body.style.overflow = "";
  });
</script>
