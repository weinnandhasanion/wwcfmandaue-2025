---
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import Layout from "@/layouts/Layout.astro";
import Meta from "@/components/Meta.astro";
import { StoryblokApi } from "@/api/storyblok";
import { getContentVersion } from "@/utils/helper";
import { isAllowedToPreview } from "@/utils/helper";

const { slug = "home" } = Astro.params;

let story;
const previewMode = isAllowedToPreview(Astro.request);
if (previewMode) {
  Astro.response.headers.set("X-Storyblok-Preview-Mode", "true");
  Astro.response.headers.set("cache-control", "no-store");
}

try {
  story = await StoryblokApi.getPage(slug, {
    version: getContentVersion(previewMode),
  });

  if (!story) {
    throw new Error(`Story with slug "${slug}" not found`);
  }
} catch (error: any) {
  if (error.status === 404) {
    return new Response(null, {
      status: 404,
      statusText: "Not found",
    });
  }
}

// The browser should always check freshness
Astro.response.headers.set(
  "cache-control",
  "public, max-age=0, must-revalidate",
);
// The CDN should cache for a year, but revalidate if the cache tag changes
Astro.response.headers.set("netlify-cdn-cache-control", "s-maxage=31536000");
// Tag the response with the slug so we can purge it later
Astro.response.headers.set("netlify-cache-tag", slug);
---

<Layout>
  <Meta slot="head" title="Home" description="This is the home page" />

  <StoryblokComponent blok={story.content} {...story} />
</Layout>
